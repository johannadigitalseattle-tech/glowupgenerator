<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Boss Glow AI Generator – Fierce Headshots</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #0a0808;
  --ink2: #1a1515;
  --ink3: #241e1e;
  --rose: #ff00a8;
  --rose2: #ff40c0;
  --rose-dim: rgba(255,0,168,0.08);
  --rose-glow: rgba(255,0,168,0.30);
  --gold: #c9a94b;
  --gold-dim: rgba(201,169,75,0.12);
  --terracotta: #c4622d;
  --terracotta-dim: rgba(196,98,45,0.1);
  --steel: #7a9cb8;
  --steel-dim: rgba(122,156,184,0.1);
  --amber: #d4832a;
  --amber-dim: rgba(212,131,42,0.1);
  --muted: #6b6060;
  --muted2: #3d3535;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.1);
  --text: #f0ece5;
  --text2: #bab4ac;
}

html { scroll-behavior: smooth; }

body {
  background: var(--ink);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  min-height: 100vh;
  overflow-x: hidden;
}

/* GRAIN OVERLAY */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
  opacity: 0.6;
}

/* ═══════════ HERO HEADER ═══════════ */
.hero {
  position: relative;
  padding: 56px 60px 44px;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(240,20,60,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.hero::after {
  content: 'BOSS GLOW';
  position: absolute;
  right: 50px; top: 50%;
  transform: translateY(-50%);
  font-family: 'Cormorant Garamond', serif;
  font-size: 160px;
  font-weight: 700;
  color: rgba(255,255,255,0.02);
  letter-spacing: -0.03em;
  pointer-events: none;
  white-space: nowrap;
}

.hero-inner {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 40px;
}

.brand {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.brand-eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--rose);
}
.brand-eyebrow::before {
  content: '';
  width: 24px; height: 1px;
  background: var(--rose);
}

.brand-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 72px;
  font-weight: 700;
  line-height: 0.9;
  letter-spacing: -0.02em;
  color: var(--text);
}
.brand-title .glow {
  color: var(--rose);
  font-style: italic;
}

.brand-sub {
  font-size: 11px;
  color: var(--muted);
  font-weight: 300;
  letter-spacing: 0.05em;
  margin-top: 4px;
}
.brand-sub em { color: var(--text2); font-style: normal; }

.hero-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10px;
}

.price-badge {
  background: var(--rose);
  color: #fff;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 6px 16px;
  display: inline-block;
}

.hero-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.hero-tag {
  border: 1px solid var(--border2);
  color: var(--muted);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 2px;
}

/* INSTRUCTIONS BAR */
.instr {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.instr-step {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 24px;
  border-right: 1px solid var(--border);
}
.instr-step:last-child { border-right: none; }
.instr-n {
  width: 24px; height: 24px;
  border: 1px solid var(--rose);
  color: var(--rose);
  font-size: 11px;
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
}
.instr-text { font-size: 11px; color: var(--text2); line-height: 1.4; }
.instr-text strong { color: var(--text); font-weight: 500; display: block; }

/* ═══════════ MAIN LAYOUT ═══════════ */
.main {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px 60px;
  display: grid;
  grid-template-columns: 1fr 440px;
  gap: 40px;
  align-items: start;
  position: relative;
  z-index: 1;
}

/* ═══════════ SECTIONS ═══════════ */
.form { display: flex; flex-direction: column; gap: 2px; }

.section {
  border: 1px solid var(--border);
  border-radius: 0;
  overflow: hidden;
  transition: border-color 0.2s;
}
.section:first-child { border-radius: 12px 12px 0 0; }
.section:last-child { border-radius: 0 0 12px 12px; }
.section + .section { border-top: none; }

.section-hdr {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 22px;
  background: var(--ink2);
  cursor: pointer;
  user-select: none;
  transition: background 0.15s;
}
.section-hdr:hover { background: var(--ink3); }
.section-hdr.active { background: var(--ink3); border-bottom: 1px solid var(--border); }

.sec-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 300;
  color: var(--rose);
  width: 30px;
  text-align: center;
  flex-shrink: 0;
}
.sec-info { flex: 1; }
.sec-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.02em;
}
.sec-desc { font-size: 10px; color: var(--muted); margin-top: 1px; font-weight: 300; }
.sec-arrow {
  font-size: 12px; color: var(--muted);
  transition: transform 0.2s;
}
.section-hdr.active .sec-arrow { transform: rotate(180deg); }

.section-body {
  display: none;
  padding: 22px;
  background: rgba(255,255,255,0.01);
  flex-direction: column;
  gap: 16px;
}
.section-body.open { display: flex; }

/* ═══════════ STYLE CARDS ═══════════ */
.style-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.style-card {
  border: 1.5px solid var(--border2);
  border-radius: 10px;
  padding: 18px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.style-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.2s;
}
.style-card.fierce::before { background: radial-gradient(circle at top right, rgba(240,20,60,0.08), transparent); }
.style-card.money::before { background: radial-gradient(circle at top right, rgba(201,169,75,0.08), transparent); }
.style-card:hover { border-color: var(--border2); }
.style-card:hover::before { opacity: 1; }
.style-card.on.fierce { border-color: var(--rose); background: var(--rose-dim); }
.style-card.on.fierce::before { opacity: 1; }
.style-card.on.money { border-color: var(--gold); background: var(--gold-dim); }
.style-card.on.money::before { opacity: 1; }
.style-card.beauty::before { background: radial-gradient(circle at top right, rgba(196,98,45,0.1), transparent); }
.style-card.on.beauty { border-color: var(--terracotta); background: var(--terracotta-dim); }
.style-card.on.beauty::before { opacity: 1; }
.sc-pill.beauty { background: rgba(196,98,45,0.15); color: var(--terracotta); }
.style-card.chic::before { background: radial-gradient(circle at top right, rgba(122,156,184,0.1), transparent); }
.style-card.on.chic { border-color: var(--steel); background: var(--steel-dim); }
.style-card.on.chic::before { opacity: 1; }
.sc-pill.chic { background: rgba(122,156,184,0.15); color: var(--steel); }
.style-card.concept::before { background: radial-gradient(circle at top right, rgba(212,131,42,0.1), transparent); }
.style-card.on.concept { border-color: var(--amber); background: var(--amber-dim); }
.style-card.on.concept::before { opacity: 1; }
.sc-pill.concept { background: rgba(212,131,42,0.15); color: var(--amber); }

.sc-icon { font-size: 28px; margin-bottom: 10px; display: block; }
.sc-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}
.sc-desc { font-size: 10px; color: var(--muted); line-height: 1.5; font-weight: 300; }
.sc-pill {
  display: inline-block;
  margin-top: 8px;
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 10px;
}
.sc-pill.fierce { background: rgba(240,20,60,0.15); color: var(--rose); }
.sc-pill.money { background: rgba(201,169,75,0.15); color: var(--gold); }

/* ═══════════ FORM ELEMENTS ═══════════ */
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }

.field { display: flex; flex-direction: column; gap: 6px; }
.label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
}
.label .opt { color: var(--muted2); font-weight: 400; text-transform: none; letter-spacing: 0; }

.sel-wrap { position: relative; }
.sel-wrap::after {
  content: '▾';
  position: absolute;
  right: 12px; top: 50%;
  transform: translateY(-50%);
  font-size: 10px; color: var(--muted2);
  pointer-events: none;
}
select {
  width: 100%;
  padding: 10px 30px 10px 12px;
  background: var(--ink2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  appearance: none;
  outline: none;
  cursor: pointer;
  transition: border-color 0.15s;
}
select option { background: var(--ink2); }
select:focus { border-color: var(--rose); }

input[type="text"], textarea {
  width: 100%;
  padding: 10px 12px;
  background: var(--ink2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  outline: none;
  transition: border-color 0.15s;
  resize: none;
}
input::placeholder, textarea::placeholder { color: var(--muted2); font-size: 11px; }
input:focus, textarea:focus { border-color: var(--rose); }

.or-divider {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 9px;
  color: var(--muted2);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.or-divider::before, .or-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* CHECKBOX TAGS */
.tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag {
  border: 1px solid var(--border2);
  border-radius: 4px;
  padding: 6px 12px;
  cursor: pointer;
  font-size: 11px;
  color: var(--muted);
  transition: all 0.15s;
  user-select: none;
  background: var(--ink2);
}
.tag:hover { border-color: var(--border2); color: var(--text2); }
.tag.on { border-color: var(--rose); background: var(--rose-dim); color: var(--text); }
.tag.on.gold-tag { border-color: var(--gold); background: var(--gold-dim); color: var(--text); }

/* COLOR PALETTE */
.palette { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
.pal-item {
  cursor: pointer;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid transparent;
  transition: all 0.2s;
  position: relative;
}
.pal-item:hover { border-color: var(--border2); }
.pal-item.on { border-color: var(--rose); }
.pal-swatch { height: 36px; width: 100%; }
.pal-name {
  background: var(--ink2);
  font-size: 9px;
  text-align: center;
  padding: 5px 4px;
  color: var(--muted);
  letter-spacing: 0.05em;
}
.pal-item.on .pal-name { color: var(--text2); }

/* SIGN INPUT */
.sign-wrap {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--ink2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.15s;
}
.sign-wrap:focus-within { border-color: var(--rose); }
.sign-prefix {
  padding: 10px 12px;
  font-size: 10px;
  color: var(--muted);
  border-right: 1px solid var(--border);
  white-space: nowrap;
  font-weight: 500;
  letter-spacing: 0.05em;
}
.sign-wrap input {
  border: none;
  border-radius: 0;
  background: transparent;
  flex: 1;
}
.sign-wrap input:focus { border-color: transparent; }

/* ═══════════ OUTPUT PANEL ═══════════ */
.output-panel {
  position: sticky;
  top: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.gen-btn {
  width: 100%;
  background: var(--rose);
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 18px 24px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 600;
  font-style: italic;
  letter-spacing: 0.03em;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  position: relative;
  overflow: hidden;
}
.gen-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
  opacity: 0;
  transition: opacity 0.2s;
}
.gen-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 36px var(--rose-glow); }
.gen-btn:hover::before { opacity: 1; }
.gen-btn:active { transform: translateY(0); }

/* PROMPT BLOCK */
.prompt-block {
  background: var(--ink2);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.pb-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--ink3);
}
.pb-tool {
  display: flex;
  align-items: center;
  gap: 10px;
}
.pb-indicator {
  width: 6px; height: 6px;
  border-radius: 50%;
}
.pb-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.pb-actions {
  display: flex;
  gap: 6px;
}
.pb-btn {
  background: transparent;
  border: 1px solid var(--border2);
  border-radius: 6px;
  color: var(--muted);
  font-family: 'DM Sans', sans-serif;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 5px 12px;
  cursor: pointer;
  transition: all 0.15s;
}
.pb-btn:hover { border-color: var(--rose); color: var(--rose); }
.pb-btn.copied { border-color: #10b981; color: #10b981; }

.pb-body { padding: 18px; min-height: 80px; }
.pb-prompt {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  line-height: 1.85;
  color: var(--text2);
  font-style: italic;
}
.pb-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 70px;
}
.pb-empty-icon { font-size: 24px; opacity: 0.25; }
.pb-empty-text { font-size: 11px; color: var(--muted2); text-align: center; line-height: 1.6; }
.pb-tip {
  font-size: 10px;
  color: var(--muted2);
  padding: 10px 18px;
  border-top: 1px solid var(--border);
  line-height: 1.5;
  font-weight: 300;
}
.pb-tip em { color: var(--rose); font-style: normal; }

/* SHAY CREDIT */
.shay-credit {
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 18px;
  background: linear-gradient(135deg, rgba(240,20,60,0.04), transparent);
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.shay-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
.shay-text { }
.shay-name { font-size: 11px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.shay-desc { font-size: 10px; color: var(--muted); line-height: 1.5; font-weight: 300; }
.shay-desc em { color: var(--rose); font-style: normal; }

/* RESET BTN */
.reset-btn {
  width: 100%;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px;
  color: var(--muted2);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.15s;
}
.reset-btn:hover { border-color: var(--border2); color: var(--muted); }

.rand-btn {
  width: 100%;
  background: transparent;
  border: 1.5px solid var(--border2);
  border-radius: 10px;
  padding: 13px;
  color: var(--text2);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.02em;
}
.rand-btn:hover {
  border-color: var(--gold);
  color: var(--gold);
  background: var(--gold-dim);
}

/* LANG TOGGLE */
.lang-toggle {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1.5px solid var(--border2);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 10px;
}
.lang-btn {
  padding: 7px 16px;
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  border: none;
  background: transparent;
  color: var(--muted);
  transition: all 0.15s;
}
.lang-btn.active {
  background: var(--rose);
  color: #fff;
}
.lang-btn:hover:not(.active) { color: var(--text2); }
  border-top: 1px solid var(--border);
  padding: 20px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 10px;
  color: var(--muted2);
  position: relative;
  z-index: 1;
}
.footer {
  border-top: 1px solid var(--border);
  padding: 24px 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 10px;
  color: var(--muted2);
  position: relative;
  z-index: 1;
  text-align: center;
}
.footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 15px; color: var(--muted); }
.footer-brand em { color: var(--rose); font-style: italic; }
.footer-note { text-align: center; line-height: 1.5; font-size: 11px; color: var(--muted); }
.footer-note em { color: var(--rose); font-style: normal; font-weight: 600; }

@media(max-width: 940px) {
  .hero { padding: 32px 24px 28px; }
  .hero::after { display: none; }
  .main { grid-template-columns: 1fr; padding: 24px; }
  .instr { flex-wrap: wrap; }
  .instr-step { min-width: 50%; }
  .output-panel { position: relative; top: 0; }
  .footer { padding: 20px 24px; }
  .row2 { grid-template-columns: 1fr; }
  .palette { grid-template-columns: repeat(5, 1fr); }
}
</style>
</head>
<body>

<!-- HERO -->
<header class="hero">
  <div class="hero-inner">
    <div class="brand">
      <div class="brand-eyebrow" data-i18n="eyebrow">AI Headshot Prompt Generator</div>
      <div class="brand-title">Boss<span class="glow">Glow</span></div>
      <div class="brand-sub">Johanna Digital, Seattle</div>
    </div>
    <div class="hero-right">
      <div class="lang-toggle">
        <button class="lang-btn active" id="btn-en" onclick="setLang('en')">EN</button>
        <button class="lang-btn" id="btn-es" onclick="setLang('es')">ES</button>
      </div>
