function setLang(lang) {
  currentLang = lang;
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
  document.getElementById('btn-es').classList.toggle('active', lang === 'es');

  const t = T[lang];

  // Update all data-i18n elements
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    if (t[key] !== undefined) el.innerHTML = t[key];
  });

  // Update select placeholders (first option)
  document.querySelectorAll('select').forEach(sel => {
    const first = sel.querySelector('option[value=""]');
    if (first) first.textContent = t.sel_default;
  });

  // Update specific select option labels
  const optionMap = {
    // skin
    'smooth glowing fair skin': t.skin_fair,
    'smooth glowing light tan skin': t.skin_tan,
    'smooth glowing brown skin': t.skin_brown,
    'smooth glowing warm brown skin': t.skin_warm,
    'smooth glowing deep brown skin': t.skin_deep,
    'smooth glowing rich dark skin': t.skin_dark,
    // eyes
    'big sparkling eyes': t.eyes_spark,
    'a smoldering, hypnotic stare that holds secrets and undeniable power': t.eyes_smolder,
    'an intensely commanding gaze': t.eyes_command,
    'deep hypnotic almond-shaped eyes': t.eyes_almond,
    'fierce confident eyes': t.eyes_fierce,
    'soft dreamy eyes': t.eyes_dreamy,
  };
  document.querySelectorAll('select option').forEach(opt => {
    if (opt.value && optionMap[opt.value]) opt.textContent = optionMap[opt.value];
  });

  // Update compound labels (data-lbl)
  document.querySelectorAll('[data-lbl]').forEach(el => {
    const key = el.dataset.lbl;
    const optKey = el.dataset.lblopt;
    const optSpan = el.querySelector('.opt');
    if (t[key]) {
      for (let node of el.childNodes) {
        if (node.nodeType === 3) { node.textContent = t[key] + ' '; break; }
      }
    }
    if (optSpan && t[optKey]) optSpan.textContent = t[optKey];
  });

  // Update placeholders
  const phMap = {
    'hairCustom': t.ph_hair, 'makeupCustom': t.ph_makeup,
    'nailCustom': t.ph_nail, 'conceptPropCustom': t.ph_prop,
    'outfitCustom': t.ph_outfit, 'accsCustom': t.ph_accs,
    'signText': t.ph_sign, 'poseCustom': t.ph_pose,
    'bgCustom': t.ph_bg, 'vibeCustom': t.ph_vibe,
  };
  Object.entries(phMap).forEach(([id, ph]) => {
    const el = document.getElementById(id);
    if (el) el.placeholder = ph;
  });

  // Update tags
  const tagMap = {
    'layered diamond chains': t.tag_chains,
    'gold hoop earrings': t.tag_hoops,
    'stacks of cash': t.tag_cash,
    'luxury designer handbag': t.tag_bag,
    'oversized designer sunglasses': t.tag_shades,
    'diamond tennis bracelet': t.tag_bracelet,
    'luxury watch': t.tag_watch,
    'floating money around her': t.tag_money,
    'bold statement rings': t.tag_rings,
    'pearl necklace': t.tag_pearl,
    'with water droplets glistening on her luminous skin': t.se_drops,
    'metallic shimmer radiating from her cheekbones': t.se_shimmer,
    'skin looks luminous and airbrushed': t.se_glow,
    'meticulously sculpted baby hairs framing her face': t.se_baby,
    'wet-look glistening skin': t.se_wet,
    'floating money raining around her': t.sc_money,
    'luxury handbags floating in the background': t.sc_bags,
    'neon glow accents illuminating the scene': t.sc_neon,
    'mirror-black reflective floor beneath her': t.sc_mirror,
    'dramatic atmospheric smoke and fog': t.sc_fog,
    'golden light rays streaming through': t.sc_gold,
    'chunky silver rings on multiple fingers': t.ring_silver,
    'gold statement rings stacked on multiple fingers': t.ring_gold,
    'diamond rings catching the light': t.ring_diamond,
    'minimalist thin gold bands': t.ring_thin,
    'bold oversized cocktail ring': t.ring_cocktail,
  };
  document.querySelectorAll('.tag').forEach(tag => {
    const val = tag.dataset.val;
    if (val && tagMap[val]) tag.textContent = tagMap[val];
  });

  // or-divider text
  document.querySelectorAll('.or-divider').forEach(el => {
    el.textContent = t.or_write;
  });
}

