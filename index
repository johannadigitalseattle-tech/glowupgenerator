function setPromptOutput(id, text) {
  const el = document.getElementById(id);
  el.className = 'pb-prompt';
  el.textContent = text;
}

function copyPrompt(id, btn) {
  const el = document.getElementById(id);
  if (!el || el.classList.contains('pb-empty')) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    btn.textContent = '✓ Copied';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2500);
  });
}

function resetAll() {
  promptStyle = 'fierce';
  selectedColor = null;

  document.querySelectorAll('.tag').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.pal-item').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('select').forEach(s => s.value = '');
  document.querySelectorAll('input[type="text"]').forEach(i => i.value = '');

  setStyle('fierce');
  const bf = document.getElementById('beauty-fields');
  if (bf) bf.style.display = 'none';
  const cf = document.getElementById('chic-fields');
  if (cf) cf.style.display = 'none';
  const xf = document.getElementById('concept-fields');
  if (xf) xf.style.display = 'none';

  ['gem-out', 'gpt-out'].forEach(id => {
    const el = document.getElementById(id);
    el.className = 'pb-empty';
    el.innerHTML = `<div class="pb-empty-icon">✨</div><div class="pb-empty-text">Your prompt will appear here<br>after you press Generate</div>`;
  });
}

