<script>
// ══════════════════════════
// STATE
// ══════════════════════════
let promptStyle = 'fierce';
let selectedColor = null;

function getTagValues(containerId) {
  return Array.from(document.querySelectorAll(`#${containerId} .tag.on`))
    .map(t => t.dataset.val);
}

// ══════════════════════════
// UI INTERACTIONS
// ══════════════════════════
function toggleSection(hdr) {
  const body = hdr.nextElementSibling;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  hdr.classList.toggle('active', !isOpen);
  if (!isOpen) body.style.display = 'flex';
  else body.style.display = 'none';
}

// Init: open first section
document.querySelectorAll('.section-body.open').forEach(b => b.style.display = 'flex');

function setStyle(s) {
  promptStyle = s;
  ['fierce','money','beauty','chic','concept'].forEach(id => {
    const el = document.getElementById('sc-' + id);
    if (el) el.classList.toggle('on', s === id);
  });
  const extras = document.getElementById('skin-extras-field');
  if (extras) extras.style.opacity = s === 'fierce' ? '1' : '0.35';
  const beautyFields = document.getElementById('beauty-fields');
  if (beautyFields) beautyFields.style.display = s === 'beauty' ? 'flex' : 'none';
  const chicFields = document.getElementById('chic-fields');
  if (chicFields) chicFields.style.display = s === 'chic' ? 'flex' : 'none';
  const conceptFields = document.getElementById('concept-fields');
  if (conceptFields) conceptFields.style.display = s === 'concept' ? 'flex' : 'none';
}

function toggleColor(el) {
  const val = el.dataset.val;
  document.querySelectorAll('.pal-item').forEach(p => p.classList.remove('on'));
  if (selectedColor === val) { selectedColor = null; }
  else { selectedColor = val; el.classList.add('on'); }
}

// Tag toggles — event delegation for all current and future tags
document.addEventListener('click', e => {
  if (e.target.classList.contains('tag')) {
    e.target.classList.toggle('on');
  }
});

function g(id) { return (document.getElementById(id)?.value || '').trim(); }
function pick(s, c) { return g(c) || g(s); }
function cap(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }

function getData() {
  const accsCustom = g('accsCustom');
  const nailCustom = g('nailCustom');
  return {
    skin: g('skin'),
    eyes: g('eyes'),
    hair: pick('hair', 'hairCustom'),
    makeup: pick('makeup', 'makeupCustom'),
    outfit: pick('outfit', 'outfitCustom'),
    pose: pick('pose', 'poseCustom'),
    bg: pick('bg', 'bgCustom'),
    sign: g('signText'),
    vibe: pick('vibe', 'vibeCustom'),
    color: selectedColor,
    accs: [...getTagValues('accs'), ...(accsCustom ? [accsCustom] : [])],
    skinExtras: getTagValues('skinExtras'),
    sceneExtras: getTagValues('sceneExtras'),
    // beauty
    nailShape: g('nailShape'),
    nailColor: nailCustom || g('nailColor'),
    rings: getTagValues('ringsExtras'),
    beautyBg: g('beautyBg'),
    // chic
    chicPose: g('chicPoseCustom') || g('chicPose') || pick('pose','poseCustom'),
    chicBg: pick('bg','bgCustom'),
    // concept
    conceptProp: g('conceptPropCustom') || g('conceptProp'),
    conceptBg: pick('bg','bgCustom'),
    conceptLight: g('conceptLight'),
  };
}

// ══════════════════════════
// PROMPT BUILDERS
// ══════════════════════════

// FIERCE GODDESS — poetic, detailed, Shay exact structure
function buildFierce(d, forChatGPT) {
  const parts = [];

  // OPENING — Shay uses "create this scene" for fierce
  if (forChatGPT) {
    parts.push(`Using the uploaded photos as face reference, please create this scene:`);
  } else {
    parts.push(`Using the uploaded image, create this scene:`);
  }

  // PHYSICAL PRESENCE
  let presence = [];
  if (d.skin) presence.push(`a woman with flawless ${d.skin}`);
  else presence.push(`a woman with flawless glowing skin`);
  presence.push(`and an intensely commanding presence`);
  parts.push(cap(presence.join(' ')) + '.');

  // HAIR — full Shay description
  if (d.hair) {
    parts.push(`Her ${d.hair}.`);
  }

  // GAZE — Shay always has this
  if (d.eyes && d.eyes !== 'big sparkling eyes') {
    parts.push(`She gazes directly into the camera with ${d.eyes}.`);
  } else {
    parts.push(`She gazes directly into the camera with a smoldering, hypnotic stare that holds secrets and undeniable power.`);
  }

  // MAKEUP — Shay breaks this into sentences
  if (d.makeup) {
    parts.push(cap(d.makeup) + '.');
  }

  // SKIN EXTRAS
  if (d.skinExtras.length > 0) {
    parts.push(cap(d.skinExtras.join('. ')) + '.');
  }

  // POSE
  if (d.pose) {
    parts.push(`She ${d.pose}.`);
  }

  // OUTFIT + ACCESSORIES + SIGN
  let outfit = [];
  if (d.outfit) outfit.push(`Wearing ${d.outfit}`);
  if (d.accs.length) outfit.push(`adorned with ${d.accs.join(', ')}`);
  if (d.sign) outfit.push(`and a chain that reads "${d.sign.toUpperCase()}"`);
  if (outfit.length) parts.push(outfit.join(', ') + '.');

  // LIGHTING — Shay exact
  let lighting = `Dramatic chiaroscuro studio lighting creates high contrast shadows and highlights`;
  if (d.skinExtras.some(e => e.includes('water droplets'))) {
    lighting += `, emphasizing every water droplet and shimmer`;
  } else {
    lighting += `, sculpting every feature with cinematic depth`;
  }
  parts.push(lighting + '.');

  // BACKGROUND + COLOR + SIGN
  let bg = '';
  if (d.bg) {
    bg = cap(d.bg);
    if (d.sign && d.bg.includes('sign')) bg += ` that reads "${d.sign.toUpperCase()}"`;
  }
  if (d.sceneExtras.length) {
    bg += (bg ? ', with ' : '') + d.sceneExtras.join(', ');
  }
  if (d.color) bg += (bg ? '. ' : '') + `${cap(d.color)} tones dominate the palette`;
  if (bg) parts.push(cap(bg) + '.');

  // VIBE — Shay puts this near the end
  if (d.vibe) {
    parts.push(cap(d.vibe) + '.');
  } else {
    parts.push(`Editorial fashion photography meets fierce goddess energy, exuding raw sexuality, unapologetic confidence, and magnetic allure.`);
  }

  // TECHNICAL — Shay exact
  parts.push(`Shot on a DSLR, shallow depth of field, high contrast, ultra-realistic, editorial lifestyle photography, Instagram aesthetic, cinematic realism.`);

  // CLOSING — Shay exact
  parts.push(forChatGPT
    ? `Do not change my face at all. Match the face from the reference photos exactly.`
    : `Do not change my face at all.`);

  return parts.join(' ');
}

// MONEY BOSS — short, direct, fun, Shay exact structure
function buildMoney(d, forChatGPT) {
  const parts = [];

  // OPENING — Shay exact
  if (forChatGPT) {
    parts.push(`Using the uploaded photos as face reference, please create this photo --`);
  } else {
    parts.push(`Using the uploaded image, please create this photo --`);
  }

  // PHYSICAL — Shay's money prompt is one sentence for looks
  let phys = [];
  if (d.skin) phys.push(`a glamorous woman with ${d.skin}`);
  else phys.push(`a glamorous woman`);
  if (d.eyes) phys.push(d.eyes);
  if (d.hair) phys.push(`and ${d.hair}`);
  if (d.makeup) phys.push(`with ${d.makeup}`);
  if (phys.length) parts.push(phys.join(', ') + '.');

  // POSE + VIBE — Shay combines these
  let action = d.pose ? `She's ${d.pose}` : `She's posing with fierce boss energy`;
  if (d.vibe) action += `, ${d.vibe}`;
  else action += `, exuding confidence and luxury like she makes money in her sleep`;
  parts.push(action + '.');

  // OUTFIT + ACCESSORIES + SIGN
  let outfit = [];
  if (d.outfit) outfit.push(`She wears ${d.outfit}`);
  if (d.accs.length) outfit.push(`with ${d.accs.join(', ')}`);
  if (d.sign) outfit.push(`including a chain that reads "${d.sign.toUpperCase()}"`);
  if (outfit.length) parts.push(outfit.join(' ') + '.');

  // BACKGROUND + SIGN + EXTRAS — Shay's money prompt is very specific
  let scene = [];
  if (d.bg) scene.push(`The background features ${d.bg}`);
  if (d.sign) scene.push(`and a glowing sign that reads "${d.sign.toUpperCase()}"`);
  if (d.sceneExtras.length) scene.push(`with ${d.sceneExtras.join(', ')}`);
  if (scene.length) parts.push(scene.join(', ') + '.');

  // COLOR
  if (d.color) parts.push(`${cap(d.color)} tones throughout.`);

  // TECHNICAL
  parts.push(`Dramatic studio lighting, high contrast, ultra-realistic, editorial fashion photography, cinematic realism, Instagram aesthetic.`);

  // CLOSING — Shay exact
  parts.push(forChatGPT
    ? `Keep my facial features the same. Match the face from the reference photos exactly.`
    : `Keep my facial features the same.`);

  return parts.join(' ');
}

// BEAUTY EDITORIAL — Shay's luxury beauty portrait structure
function buildBeauty(d, forChatGPT) {
  const parts = [];

  // OPENING — Shay uses "Using my photo, create this image:" for beauty
  if (forChatGPT) {
    parts.push(`Using my uploaded photos, create this image:`);
  } else {
    parts.push(`Using my photo, create this image:`);
  }

  // TYPE — Shay names the genre first
  let intro = `a luxury beauty editorial portrait of a glamorous woman`;
  if (d.skin) intro += ` with ${d.skin}`;
  if (d.makeup && !d.makeup.includes('smoky')) intro += `, soft matte-glow complexion, and sculpted makeup`;
  else intro += ` and sculpted makeup`;
  parts.push(intro + '.');

  // MAKEUP — Shay is very specific in beauty style
  if (d.makeup) {
    parts.push(`${cap(d.makeup)}.`);
  } else {
    parts.push(`Full glossy nude-brown lips, softly contoured cheeks with peachy blush, and luminous highlights on the high points of the face.`);
  }

  // EYES — part of makeup description in beauty style
  if (d.eyes) {
    parts.push(`Her eyes feature ${d.eyes}, long voluminous lashes, and softly defined brows.`);
  } else {
    parts.push(`Long voluminous lashes and softly defined brows.`);
  }

  // HAIR
  if (d.hair) {
    parts.push(`Hair is ${d.hair}.`);
  }

  // HANDS + NAILS + RINGS — the signature of this Shay style
  let nailLine = `Her hands frame her face in elegant poses`;
  if (d.nailShape || d.nailColor) {
    nailLine += `, showcasing ${d.nailShape || 'long almond-shaped acrylic nails'}${d.nailColor ? ' ' + d.nailColor : ''}`;
  }
  if (d.rings.length) nailLine += `. She wears ${d.rings.join(', ')}`;
  parts.push(nailLine + '.');

  // OUTFIT
  if (d.outfit) {
    parts.push(`She wears ${d.outfit}.`);
  }

  // ACCESSORIES (non-nail)
  if (d.accs.length) {
    parts.push(`Adorned with ${d.accs.join(', ')}.`);
  }

  // SETTING — warm backdrop is the signature
  const backdrop = d.beautyBg || (d.bg ? d.bg : 'a warm terracotta and orange studio backdrop');
  parts.push(`The setting is ${backdrop} with soft diffused lighting, shallow depth of field, and a high-end editorial feel.`);

  // COLOR
  if (d.color) parts.push(`${cap(d.color)} tones accent the scene.`);

  // SCENE EXTRAS
  if (d.sceneExtras.length) parts.push(`${cap(d.sceneExtras.join(', '))}.`);

  // TECHNICAL — Shay's beauty prompt is very specific here
  parts.push(`Shot in ultra-high resolution, beauty photography, magazine cover quality, clean skin texture, polished yet natural glam aesthetic.`);

  // CLOSING — Shay uses ALL CAPS for beauty
  parts.push(forChatGPT
    ? `DO NOT CHANGE MY FACE AT ALL. Match the face from the reference photos exactly.`
    : `DO NOT CHANGE MY FACE AT ALL.`);

  return parts.join(' ');
}

// CONCEPT / THEMED — short direct, prop-centered, Shay exact structure
function buildConcept(d, forChatGPT) {
  const parts = [];

  // OPENING — Shay exact: no dash, no colon, straight into description
  if (forChatGPT) {
    parts.push(`Using the uploaded photos as face reference, create`);
  } else {
    parts.push(`Using the uploaded image, create`);
  }

  // PHYSICAL — concise, one sentence
  let phys = `a`;
  if (d.skin) phys += ` ${d.skin}`;
  phys += ` woman`;
  if (d.hair) phys += ` with ${d.hair}`;

  // PROP ACTION — central to this style
  const prop = d.conceptProp || 'a prop';
  // Extract clean prop name for lighting reference
  const propShort = prop.split(' ').slice(0,4).join(' ');
  phys += ` holding ${prop}`;
  parts.push(phys + '.');

  // MAKEUP + NAILS — Shay lists these together in concept style
  let beauty = [];
  if (d.makeup) beauty.push(`She has ${d.makeup}`);
  const nails = d.nailShape ? `${d.nailShape}${d.nailColor ? ' ' + d.nailColor : ''}` : null;
  if (nails) beauty.push(`and ${nails}`);
  if (beauty.length) parts.push(beauty.join(' ') + '.');

  // OUTFIT — short, just the item
  if (d.outfit) parts.push(`She is wearing ${d.outfit}.`);

  // ACCESSORIES
  if (d.accs.length) parts.push(`${cap(d.accs.join(', '))}.`);

  // BACKGROUND — monochromatic is the key element
  const bg = d.conceptBg || 'a solid dark background, creating a monochrome effect with her outfit and skin tone';
  parts.push(`The background is ${bg}.`);

  // LIGHTING — Shay's concept lighting note is always short
  const lightFocus = `her features and the ${propShort}`;
  parts.push(`The lighting highlights ${lightFocus}.`);

  // CLOSING — Shay exact, NO period at the end, matches original exactly
  parts.push(forChatGPT
    ? `Do not change the facial features. Match the face from reference photos exactly`
    : `Do not change the facial features`);

  return parts.join(' ');
}

// ══════════════════════════
// GENERATE
// ══════════════════════════
function generateAll() {
  const d = getData();

  let gemPrompt, gptPrompt;
  if (promptStyle === 'fierce') {
    gemPrompt = buildFierce(d, false);
    gptPrompt = buildFierce(d, true);
  } else if (promptStyle === 'money') {
    gemPrompt = buildMoney(d, false);
    gptPrompt = buildMoney(d, true);
  } else if (promptStyle === 'beauty') {
    gemPrompt = buildBeauty(d, false);
    gptPrompt = buildBeauty(d, true);
  } else if (promptStyle === 'chic') {
    gemPrompt = buildChic(d, false);
    gptPrompt = buildChic(d, true);
  } else {
    gemPrompt = buildConcept(d, false);
    gptPrompt = buildConcept(d, true);
  }

  setPromptOutput('gem-out', gemPrompt);
  setPromptOutput('gpt-out', gptPrompt);

  if (window.innerWidth < 940) {
    document.querySelector('.output-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}
function buildChic(d, forChatGPT) {
  const parts = [];

  // OPENING — Shay exact for this style
  if (forChatGPT) {
    parts.push(`Using the uploaded photos as face reference, create a photo with this scene —`);
  } else {
    parts.push(`Using the uploaded image, create a photo with this scene —`);
  }

  // TYPE + VIBE INTRO — Shay names the energy upfront in this style
  let intro = `A glamorous and confident woman posing stylishly in a chic, editorial photoshoot`;
  parts.push(intro + '.');

  // PHYSICAL
  let phys = [];
  if (d.skin) phys.push(`She has ${d.skin}`);
  if (d.hair) phys.push(`and ${d.hair} that frames her face beautifully`);
  if (phys.length) parts.push(phys.join(' ') + '.');

  // MAKEUP — Shay describes it as flawless first
  if (d.makeup) {
    parts.push(`Her makeup is flawless and elegant with ${d.makeup}.`);
  } else {
    parts.push(`Her makeup is flawless and elegant with soft contouring, glossy lips, and long, dramatic lashes.`);
  }

  // OUTFIT — the star of this style, described very specifically
  if (d.outfit) {
    parts.push(`She wears ${d.outfit}.`);
  }

  // ACCESSORIES
  const watchAcc = d.accs.find(a => a.includes('watch'));
  const otherAccs = d.accs.filter(a => !a.includes('watch'));
  if (watchAcc) parts.push(`A ${watchAcc} adorns her wrist.`);
  if (otherAccs.length) parts.push(`${cap(otherAccs.join(', '))}.`);

  // POSE — in chic style the pose includes the emotional quality
  const pose = d.chicPose || d.pose;
  if (pose) {
    parts.push(`She's ${pose}.`);
  }

  // VIBE — Shay adds energy keywords in chic style
  if (d.vibe) {
    parts.push(cap(d.vibe) + '.');
  }

  // SETTING + LIGHTING — soft, clean, editorial
  const bg = d.chicBg || d.bg || 'a neutral gray background';
  parts.push(`The lighting is soft studio light against ${bg}, highlighting her confident, poised expression.`);

  // COLOR
  if (d.color) parts.push(`${cap(d.color)} tones throughout the scene.`);

  // TECHNICAL — Shay's chic style ends with magazine quality notes
  parts.push(`High-end fashion editorial photography, realistic lighting, glossy skin tones, sharp focus, soft depth of field, magazine-quality aesthetic.`);

  // CLOSING — Shay exact (no "at all" in this style)
  parts.push(forChatGPT
    ? `DO NOT CHANGE MY FACE. Match the face from the reference photos exactly.`
    : `DO NOT CHANGE MY FACE.`);

  return parts.join(' ');
}

