// RANDOMIZE
// ══════════════════════════
function randomize() {
  // Reset first
  resetAll();

  function rnd(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  function setSelect(id, val) {
    const el = document.getElementById(id);
    if (el) el.value = val;
  }

  function pickRandom(id) {
    const el = document.getElementById(id);
    if (!el) return;
    const opts = Array.from(el.options).filter(o => o.value !== '');
    if (opts.length) el.value = rnd(opts).value;
  }

  function randomTags(containerId, count) {
    const tags = document.querySelectorAll(`#${containerId} .tag`);
    const shuffled = Array.from(tags).sort(() => Math.random() - 0.5);
    shuffled.slice(0, count).forEach(t => t.classList.add('on'));
  }

  // 1. Pick a random style
  const styles = ['fierce','money','beauty','chic','concept'];
  const chosenStyle = rnd(styles);
  setStyle(chosenStyle);

  // 2. Your Look
  pickRandom('skin');
  pickRandom('eyes');
  pickRandom('hair');
  pickRandom('makeup');

  // Style-specific
  if (chosenStyle === 'fierce') {
    randomTags('skinExtras', rnd([1,2]));
  }
  if (chosenStyle === 'beauty') {
    pickRandom('nailShape');
    pickRandom('nailColor');
    randomTags('ringsExtras', rnd([1,2]));
  }
  if (chosenStyle === 'concept') {
    pickRandom('conceptProp');
  }

  // 3. Outfit & Accessories
  pickRandom('outfit');
  randomTags('accs', rnd([2,3,4]));

  // Sign text — random pool
  const signs = ['THE BOSS','RICH TALK ONLY','BOSS MOVES','CEO','QUEEN','SHE WINS','THAT GIRL','MAIN CHARACTER'];
  if (Math.random() > 0.3) {
    document.getElementById('signText').value = rnd(signs);
  }

  // 4. Scene
  pickRandom('pose');
  pickRandom('bg');

  // Random color swatch
  const swatches = document.querySelectorAll('.pal-item');
  if (swatches.length && Math.random() > 0.4) {
    const picked = rnd(Array.from(swatches));
    toggleColor(picked);
  }

  // Scene extras — 0-2 random
  randomTags('sceneExtras', rnd([0,1,2]));

  // 5. Vibe
  pickRandom('vibe');

  // Auto-generate after randomizing
  setTimeout(() => generateAll(), 80);
}

